@using PagedList.Mvc
@using PagedList;
@model IPagedList<MVC.ViewModels.ResultVM>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<form method="get" asp-action="Index">
    <p>
        <input name="eventName" class="input-m" type="search" placeholder="Name" />
        <input type="submit" value="Search" class="btn btn-primary" />
    </p>
</form>
<table class="table">
    <tr>
        <th>
            Athlete Id
        </th>
        <th>
            Game Id
        </th>
        <th>
            Position
        </th>
        <th>
            Event
        </th>
        <th>
            Team
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.AthleteId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.GameId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Position)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Event)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Team)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.Id })
            </td>
        </tr>
    }
    <div class="form-inline">
        <div>
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, eventName = ViewBag.EventName, itemsPerPage = Model.PageSize }))
        </div>

        <div>
            <form method="get">
                <fieldset>
                    Items Per Page
                    <select id="itemsPerPage" name="itemsPerPage" onchange="ipp_change()">
                        <option @(Model.PageSize == 1 ? "selected" : "") value="1">1</option>
                        <option @(Model.PageSize == 3 ? "selected" : "") value="3">3</option>
                        <option @(Model.PageSize == 5 ? "selected" : "") value="5">5</option>
                        <option @(Model.PageSize == 10 ? "selected" : "") value="10">10</option>
                    </select>
                </fieldset>
            </form>
        </div>
    </div>
</table>

<script>
    function ipp_change() {
        let ipp = document.getElementById("itemsPerPage");
        let value = ipp.options[ipp.selectedIndex].value;

        document.location.href = "/Result/Index?page=@Model.PageNumber&itemsPerPage=" + value + "&eventName=@ViewBag.EventName";
    }
</script>
